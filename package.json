  "description": "Chrome DevTools Extension for QA automation - smart element capture with ZeuZ-format output",
  "main": "dist/background.js",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest --run"
