    "@types/chrome": "^0.2.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.3.2",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "webpack": "^5.108.2",
    "webpack-cli": "^7.1.0"
